# O app carrega automaticamente o .env na raiz do repositório (também tenta um nível acima,
# útil se o cwd for cmd/api). Sem arquivo, só variáveis já exportadas no shell contam.
#
# Obrigatórias — a API não inicia se alguma estiver ausente ou inválida.
DB_HOST=localhost
DB_PORT=5432
DB_USER=retech_meufin_user
DB_PASSWORD=d18cf320-18f3-4a88-a030-9b4069454ebf
DB_NAME=retech_meufin_db
# Local: disable | Produção (Railway, etc.): require ou verify-full conforme provedor
DB_SSLMODE=disable

APP_PORT=8002
# development | production | test
APP_ENV=development
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Caminho absoluto ou relativo ao diretório de trabalho (no Docker: /app/migrations)
MIGRATIONS_PATH=./migrations

# Autenticação — valida JWT (RS256) emitido pelo retech-auth-api via JWKS.
# Obrigatória. O workspace vem do tenant_id do token (header X-Workspace-ID não é mais usado).
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json

# Origins permitidas no CORS (admin front), separadas por vírgula. Obrigatória.
CORS_ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3001

# Opcional: se setado, rejeita tokens cujo application_id não bata (defesa em profundidade).
APP_APPLICATION_ID=

# --- Saúde Familiar: storage de documentos (MinIO) — OPCIONAL ---
# Sem estas vars, upload/download de documentos ficam indisponíveis (a API sobe normal).
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_HEALTH=retech-meufin-health
MINIO_USE_SSL=false
HEALTH_MAX_UPLOAD_MB=20

# --- Extração LLM (compartilhada por Saúde e Financeiro) — OPCIONAL ---
# Escolha a LLM aqui. provider: anthropic | disabled (default).
# Sem chave/provider, a extração fica desabilitada (upload funciona; extrair retorna erro controlado).
# MinIO (acima) também é usado pelas faturas do Financeiro.
EXTRACTION_PROVIDER=disabled
EXTRACTION_MODEL=claude-opus-4-8
EXTRACTION_API_KEY=
EXTRACTION_BASE_URL=https://api.anthropic.com

# (Compatibilidade) HEALTH_EXTRACTION_* ainda é lido como fallback se EXTRACTION_* não existir.
# HEALTH_EXTRACTION_PROVIDER=disabled
# HEALTH_EXTRACTION_API_KEY=

# Variáveis auxiliares PostgreSQL (usadas pelo docker-compose)
CONTAINER_NAME=retech-meufin-db
PGHOST=localhost
PGUSER=retech_meufin_user
PGPASSWORD=retech_meufin_dev_password
PGDATABASE=retech_meufin_db
PGPORT=5432
PGDATA=/var/lib/postgresql/data/pgdata
PGVOLUME_NAME=retech_meufin_db_volume
COMPOSE_NETWORK=retech-network
# ── Notificações por e-mail (useSend self-hosted) ──────────────────────────
# Sem essas 3 variáveis o canal de e-mail fica desabilitado (fluxo "esqueci a
# senha" retorna erro 500 ao tentar enviar).
USESEND_BASE_URL=https://usesend.suaempresa.com
USESEND_API_KEY=us_xxxxxxxxxxxxxxxx
MAIL_FROM_EMAIL=nao-responda@meufin.app
MAIL_FROM_NAME=MeuFin

# ── Cliente interno do retech-auth-api (fluxo "esqueci a senha") ───────────
AUTH_API_BASE_URL=https://retechauth-api-production.up.railway.app
# Mesmo secret compartilhado do authsync (BOOTSTRAP_SECRET no retech-auth-api)
AUTH_BOOTSTRAP_SECRET=troque-por-um-secret-forte

# Base do admin usada para montar o link de redefinição do e-mail
ADMIN_BASE_URL=https://admin.meufin.app
