# Obrigatórias — a API não inicia se alguma estiver ausente ou inválida.
DB_HOST=localhost
DB_PORT=5432
DB_USER=retechfin
DB_PASSWORD=retechfin
DB_NAME=retechfin
# Local: disable | Produção (Railway, etc.): require ou verify-full conforme provedor
DB_SSLMODE=disable

APP_PORT=8080
# development | production | test
APP_ENV=development
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Caminho absoluto ou relativo ao diretório de trabalho (no Docker: /app/migrations)
MIGRATIONS_PATH=./migrations
